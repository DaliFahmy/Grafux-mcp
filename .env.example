# =============================================================================
# Grafux-mcp Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ─── Service ──────────────────────────────────────────────────────────────────
SERVICE_NAME=grafux-mcp
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8002

# ─── Database (PostgreSQL via asyncpg) ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/grafux_mcp

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/1

# ─── Internal service auth ────────────────────────────────────────────────────
# Must match Grafux-backend's INTERNAL_SERVICE_KEYS_JSON["mcp"] value
INTERNAL_SERVICE_KEY=change_me_mcp_internal_key
BACKEND_INTERNAL_URL=http://localhost:8000
ORCHESTRATOR_INTERNAL_URL=http://localhost:8001
DEVICES_INTERNAL_URL=http://localhost:8003

# ─── OpenAI (AI-powered generated tools read these from the process env) ─────
# The MCP runtime exports OPENAI_API_KEY into the env of every tool it executes,
# also under GARAGE_OPENAI_API_KEY / GRAFUX_GPT_KEY. The model vars are optional —
# leave them blank to keep each generated tool's built-in default model; set them
# only to override (must be a model the key is entitled to).
OPENAI_API_KEY=
# GARAGE_OPENAI_TEXT_MODEL=
# GARAGE_OPENAI_IMAGE_MODEL=
# GARAGE_OPENAI_VIDEO_MODEL=

# ─── E2B ─────────────────────────────────────────────────────────────────────
E2B_API_KEY=

# ─── Composio ────────────────────────────────────────────────────────────────
COMPOSIO_API_KEY=

# ─── AWS S3 (tool file sync – preserved from v1) ─────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=grafux-user-files
S3_SYNC_INTERVAL=600

# ─── GCP Vertex AI (used by some tool plugins) ───────────────────────────────
GCP_SERVICE_ACCOUNT_JSON=

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── Execution ────────────────────────────────────────────────────────────────
DEFAULT_TOOL_TIMEOUT=120.0
MAX_CONCURRENT_INVOCATIONS=100
